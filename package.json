{
  "scripts": {
    "build": "parcel build",
    "dev:client": "parcel serve lp-client/index.html --port 1234 --host localhost --no-hmr",
    "dev:professional": "parcel serve lp-professional/index.html --port 1235 --host localhost --no-hmr",
    "dev": "parcel serve lp-client/index.html --port 1234 --host 127.0.0.1 --no-hmr",
    "dev:hot": "parcel serve lp-client/index.html --port 1234 --host 127.0.0.1",
    "dev:pm2": "npx pm2 start ecosystem.config.js",
    "dev:pm2:stop": "npx pm2 stop lp-client-dev",
    "dev:pm2:restart": "npx pm2 restart lp-client-dev",
    "dev:pm2:logs": "npx pm2 logs lp-client-dev",
    "dev:pm2:status": "npx pm2 status",
    "serve:client": "npx http-server lp-client -p 1234 -o",
    "serve:professional": "npx http-server lp-professional -p 1235 -o"
  },
  "targets": {
    "lp-client": {
      "source": "lp-client/index.html",
      "distDir": "./static-output/lp-client",
      "publicUrl": "/arrowpro-sub-contents/static-output/lp-client/",
      "sourceMap": false
    },
    "lp-professional": {
      "source": "lp-professional/index.html",
      "distDir": "./static-output/lp-professional",
      "publicUrl": "/arrowpro-sub-contents/static-output/lp-professional/",
      "sourceMap": false
    },
    "request": {
      "source": "request/index.html",
      "distDir": "./static-output/request",
      "publicUrl": "/arrowpro-sub-contents/static-output/request/",
      "sourceMap": false
    },
    "request-completed": {
      "source": "request/completed/index.html",
      "distDir": "./static-output/request/completed",
      "publicUrl": "/arrowpro-sub-contents/static-output/request/completed/",
      "sourceMap": false
    }
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.0",
    "@parcel/transformer-jsonld": "^2.16.0",
    "parcel": "^2.0.0",
    "pm2": "^6.0.14"
  }
}
